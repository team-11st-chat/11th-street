# Server Configuration
SERVER_PORT=8080
SERVER_SHUTDOWN=graceful

# Spring Configuration
SPRING_PROFILES_ACTIVE=local

# Database Configuration (MySQL)
DB_URL=jdbc:mysql://localhost:3306/realtime_chat?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_database_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JPA & Flyway
JPA_DDL_AUTO=validate
JPA_OPEN_IN_VIEW=false
FLYWAY_ENABLED=true
FLYWAY_LOCATIONS=classpath:db/migration
FLYWAY_VALIDATE_ON_MIGRATE=true

# Logging
APP_LOG_LEVEL=INFO

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_which_should_be_long_enough_for_security_reasons_at_least_256_bits
JWT_ACCESS_TOKEN_VALIDITY_SECONDS=3600
JWT_REFRESH_TOKEN_VALIDITY_SECONDS=604800

# Cache & Lock Prefix Configuration
PRODUCT_SEARCH_CACHE_MODE=LOCAL
REDIS_CACHE_KEY_PREFIX=cache:v1:
REDIS_LOCK_KEY_PREFIX=lock:

# Lock, Idempotency & Cache Settings
LOCK_DEFAULT_WAIT_SECONDS=3
LOCK_DEFAULT_LEASE_SECONDS=5
IDEMPOTENCY_REQUEST_ID_TTL_SECONDS=10
CAFFEINE_PRODUCT_SEARCH_TTL=10m
CAFFEINE_POPULAR_KEYWORDS_TTL=1m
CAFFEINE_PRODUCT_SEARCH_MAXIMUM_SIZE=10000
REDIS_DEFAULT_CACHE_TTL=10m
