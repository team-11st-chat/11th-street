### =====================================================================
### 회원 / 인증 API 테스트 (이슈 #21)
### IntelliJ HTTP Client 형식. 위에서부터 순서대로 실행하면 됩니다.
### 애플리케이션 기동: ./gradlew bootRun  (기본 포트 8080)
### =====================================================================

@host = http://localhost:8080
@email = buyer01@example.com
@password = plainPassword1
@name = 구매자01


### 1. 회원가입 - 성공 (201 Created)
# @name signup
POST {{host}}/api/v1/members
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "name": "{{name}}"
}

> {%
    client.test("201 Created", () => client.assert(response.status === 201, "status: " + response.status));
    client.test("응답에 id 가 있다", () => client.assert(response.body.data.id !== null));
    client.test("비밀번호가 응답에 없다", () => client.assert(response.body.data.password === undefined));
%}


### 2. 회원가입 - 이메일 중복 (409 Conflict)  [1번 실행 후]
POST {{host}}/api/v1/members
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "name": "다른이름"
}

> {%
    client.test("409 Conflict", () => client.assert(response.status === 409, "status: " + response.status));
%}


### 3. 회원가입 - 유효성 실패: 잘못된 이메일 형식 (400 Bad Request)
POST {{host}}/api/v1/members
Content-Type: application/json

{
  "email": "not-an-email",
  "password": "{{password}}",
  "name": "{{name}}"
}

> {%
    client.test("400 Bad Request", () => client.assert(response.status === 400, "status: " + response.status));
%}


### 4. 회원가입 - 유효성 실패: 8자 미만 비밀번호 (400 Bad Request)
POST {{host}}/api/v1/members
Content-Type: application/json

{
  "email": "shortpw@example.com",
  "password": "123",
  "name": "{{name}}"
}

> {%
    client.test("400 Bad Request", () => client.assert(response.status === 400, "status: " + response.status));
%}


### 5. 로그인 - 성공 (200 OK, accessToken 발급 + refreshToken 쿠키)
# @name login
POST {{host}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

> {%
    client.test("200 OK", () => client.assert(response.status === 200, "status: " + response.status));
    client.test("accessToken 발급", () => client.assert(response.body.data.accessToken !== null));
    client.test("tokenType 은 Bearer", () => client.assert(response.body.data.tokenType === "Bearer"));
    client.test("expiresIn 은 3600", () => client.assert(response.body.data.expiresIn === 3600));
    client.test("refreshToken 쿠키 발급(HttpOnly)", () => {
        const cookie = response.headers.valueOf("Set-Cookie");
        client.assert(cookie !== null && cookie.indexOf("refreshToken=") >= 0, "Set-Cookie: " + cookie);
        client.assert(cookie.indexOf("HttpOnly") >= 0, "HttpOnly 누락");
    });
    client.global.set("accessToken", response.body.data.accessToken);
%}


### 6. 로그인 - 비밀번호 오류 (401 Unauthorized)
POST {{host}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "wrongPassword!"
}

> {%
    client.test("401 Unauthorized", () => client.assert(response.status === 401, "status: " + response.status));
%}


### 7. 로그인 - 존재하지 않는 이메일 (401 Unauthorized)
POST {{host}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "nobody@example.com",
  "password": "{{password}}"
}

> {%
    client.test("401 Unauthorized", () => client.assert(response.status === 401, "status: " + response.status));
%}


### 8. 로그인 - 유효성 실패: 빈 비밀번호 (400 Bad Request)
POST {{host}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": ""
}

> {%
    client.test("400 Bad Request", () => client.assert(response.status === 400, "status: " + response.status));
%}


### -----------------------------------------------------------------
### 참고: 5번 로그인 성공 후 발급된 accessToken 은 {{accessToken}} 으로 참조됩니다.
### 현재 보호된(인증 필요) 엔드포인트가 없어 Bearer 인증 호출 예시는 주석으로만 둡니다.
### 재발급(/auth/reissue)·로그아웃(/auth/logout)은 별도 이슈로 미구현 상태입니다.
### -----------------------------------------------------------------
# GET {{host}}/api/v1/<protected-endpoint>
# Authorization: Bearer {{accessToken}}
